{
  "name": "@aide-os/mcp-hub",
  "version": "0.0.0",
  "description": "MCP server exposing aide triage / task / draft / style / brief state",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aide-mcp-hub": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/bin.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aide-os/storage": "workspace:*",
    "@aide-os/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "zod": "^3.24.1"
  }
}
