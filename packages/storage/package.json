{
  "name": "@chief-of-staff/storage",
  "version": "0.0.0",
  "description": "Pluggable storage adapters for chief-of-staff (filesystem, notion)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./filesystem": {
      "types": "./dist/filesystem.d.ts",
      "import": "./dist/filesystem.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chief-of-staff/types": "workspace:*"
  }
}
