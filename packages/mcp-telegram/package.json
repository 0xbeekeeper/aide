{
  "name": "@aide-os/mcp-telegram",
  "version": "0.0.0",
  "description": "MCP server exposing the user's Telegram inbox via a user session (gramjs)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aide-mcp-telegram": "./dist/bin.js",
    "aide-tg-login": "./dist/login.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./login": {
      "types": "./dist/login.d.ts",
      "import": "./dist/login.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin.js dist/login.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/bin.ts",
    "login": "tsx src/login.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aide-os/storage": "workspace:*",
    "@aide-os/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "input": "^1.0.1",
    "telegram": "^2.26.22",
    "zod": "^3.24.1"
  }
}
