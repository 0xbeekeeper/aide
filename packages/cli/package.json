{
  "name": "@aide-os/cli",
  "version": "0.0.0",
  "description": "aide CLI — runs skills, manages config, orchestrates MCP servers.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aide": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/bin.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/bin.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aide-os/mcp-hub": "workspace:*",
    "@aide-os/mcp-telegram": "workspace:*",
    "@aide-os/storage": "workspace:*",
    "@aide-os/types": "workspace:*",
    "commander": "^12.1.0",
    "kleur": "^4.1.5"
  }
}
